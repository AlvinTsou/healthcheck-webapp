# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=global
GCP_DATASTORE_ID=your-datastore-id
GCP_BUCKET_NAME=your-gcs-bucket-name


# Gemini Model Settings
# Typically gemini-1.5-pro or gemini-1.5-flash
GEMINI_MODEL=gemini-2.5-flash

# MVP Invitation & Quota System Configuration
# Allowed invitation codes. Support custom limit format (e.g. CODE:LIMIT, comma-separated)
# If no custom limit is specified, it will default to MAX_QUOTA.
INVITATION_CODES=PAPAGO2026:50,VIP888:100,TRIAL10:10
# Default max allowed usage per code if not explicitly set
MAX_QUOTA=50
# Secret admin token for resetting the quota (e.g. via reset API)
ADMIN_TOKEN=my-secret-reset-token

# Firebase Web Client Configuration (提供前端連線使用)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain
FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id
FIREBASE_APP_ID=your-firebase-app-id

